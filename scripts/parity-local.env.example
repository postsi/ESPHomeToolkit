# Copy to scripts/.parity-local.env (gitignored) so run-designer-mac-parity.sh / parity:mac
# pick up HA + device without exporting in every shell.
#
# ESPTOOLKIT_ENTRY_ID is optional when you have a single EspToolkit config entry.

ESPTOOLKIT_HA_URL=http://grimwoodha:8123
ESPTOOLKIT_PARITY_DEVICE_ID=yellow_p4
# ESPTOOLKIT_ENTRY_ID=
# ESPTOOLKIT_HA_TOKEN=
# ESPTOOLKIT_HA_INSECURE_SSL=1
# Optional Quartz capture tuning (if sim PNG doesn’t match what you see on screen):
# PARITY_CAPTURE_STABILIZE_S=0.85
# PARITY_CAPTURE_STRICT_SDL=1
